# --- Django ---
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (per-service DB) ---
DATABASE_URL=postgres://smarthr_retention:change-me@localhost:5432/smarthr_retention

# --- JWT verification (public key from smarthr360-auth) ---
SMARTHR_JWT_PUBLIC_KEY_FILE=/run/secrets/jwt_public.pem
SMARTHR_JWT_ISSUER=smarthr360

# --- LLM for need extraction (optional; keyword fallback without it) ---
NEBIUS_API_KEY=
